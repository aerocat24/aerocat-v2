<?xml version="1.0"?>
<launch>
    
    <include file="$(find boat)/launch/remote_control.launch">

        <arg name="name" value="tbsim_1"/>
        <arg name="keyboard_name" value="tbsim_k_1"/>
        <arg name="vel_topic" value="tb1_vel"/>
        <arg name="show_sim" value="true"/>
        <param name="/tbsim_1/background_b" value="0"/>
        
    </include>

